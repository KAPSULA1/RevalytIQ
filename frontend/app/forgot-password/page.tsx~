"use client";

import { FormEvent, useState } from "react";
import Link from "next/link";
import { isAxiosError } from "axios";
import { requestPasswordReset } from "@/lib/auth";

export default function ForgotPasswordPage() {
  const [email, setEmail] = useState("");
  const [error, setError] = useState("");
  const [info, setInfo] = useState<{ detail: string; uid?: string; token?: string } | null>(
    null,
  );
  const [loading, setLoading] = useState(false);

  const handleSubmit = async (event: FormEvent<HTMLFormElement>) => {
    event.preventDefault();
    setError("");
    setInfo(null);

    if (!email.trim()) {
      setError("Email is required.");
      return;
    }

    setLoading(true);
    try {
      const data = await requestPasswordReset(email.trim());
      setInfo({
        detail: data.detail,
        uid: data.reset.uid,
        token: data.reset.token,
      });
    } catch (err) {
      if (isAxiosError(err)) {
        const message =
          typeof err.response?.data === "string"
            ? err.response.data
            : err.response?.data?.detail ?? "Unable to process request.";
        setError(message);
      } else {
        setError("Unexpected error. Please try again.");
      }
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="flex items-center justify-center min-h-screen bg-gray-50">
      <form
        onSubmit={handleSubmit}
        className="bg-white shadow-lg rounded-2xl p-6 w-96 flex flex-col gap-4"
      >
        <h2 className="text-2xl font-semibold text-center">Forgot Password</h2>
        <p className="text-sm text-gray-600 text-center">
          Enter your account email. We will generate a reset token you can use to set a new
          password.
        </p>
        <input
          type="email"
          placeholder="you@example.com"
          value={email}
          onChange={(event) => setEmail(event.target.value)}
          className="border p-2 rounded-lg focus:ring focus:ring-blue-300"
        />

        {error && <p className="text-red-600 text-sm text-center">{error}</p>}

        <button
          type="submit"
          disabled={loading}
          className="bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition disabled:opacity-70"
        >
          {loading ? "Requesting..." : "Send Reset Instructions"}
        </button>

        {info && (
          <div className="bg-blue-50 border border-blue-200 rounded-lg p-3 text-sm text-blue-700">
            <p className="font-semibold">{info.detail}</p>
            <p className="mt-2">Use the following values on the reset page:</p>
            <pre className="mt-2 whitespace-pre-wrap break-words">
              UID: {info.uid}
              {"\n"}
              Token: {info.token}
            </pre>
          </div>
        )}

        <div className="flex justify-between text-sm">
          <Link className="text-blue-600 hover:underline" href="/">
            Back to Login
          </Link>
          <Link className="text-blue-600 hover:underline" href="/reset-password">
            Already have a token?
          </Link>
        </div>
      </form>
    </div>
  );
}
